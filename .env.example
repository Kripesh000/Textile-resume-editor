# ── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite - no setup required):
DATABASE_URL=sqlite+aiosqlite:///./textile.db

# Production (PostgreSQL on Render - replace with your actual connection string):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random value for production:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of exact allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Regex for additional allowed origins (Vercel preview deployments)
CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app

# ── LaTeX Compilation ─────────────────────────────────────────────────────────
# Path to the tectonic binary (absolute path)
# Development (macOS arm64 - binary included in repo):
TECTONIC_PATH=/absolute/path/to/resumeeditor/frontend/tectonic
# Production: install tectonic on the server and set the path

# ── AI Parsing (optional) ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Auth ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_HOURS=24
