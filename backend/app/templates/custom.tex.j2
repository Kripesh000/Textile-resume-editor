\documentclass[letterpaper,\VAR{config.font_size | default(11)}pt]{article}

\usepackage[utf8]{inputenc}
\usepackage[T1]{fontenc}
\usepackage{lmodern}
\usepackage[margin=\VAR{config.margin | default(0.5)}in]{geometry}
\usepackage{enumitem}
\usepackage{titlesec}
\usepackage{hyperref}
\usepackage{xcolor}

\BLOCK{if config.accent_color}
\definecolor{accent}{HTML}{\VAR{config.accent_color | replace('#', '')}}
\BLOCK{else}
\definecolor{accent}{HTML}{000000}
\BLOCK{endif}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\BLOCK{if config.compact}
\setlist[itemize]{nosep, leftmargin=1.5em, topsep=1pt}
\BLOCK{else}
\setlist[itemize]{nosep, leftmargin=1.5em, topsep=2pt}
\BLOCK{endif}

%# --- Section heading style ---
\BLOCK{if config.section_style == 'color_rule'}
\titleformat{\section}{\large\bfseries\color{accent}}{}{0em}{}[\color{accent}\titlerule]
\BLOCK{elif config.section_style == 'plain'}
\titleformat{\section}{\large\bfseries}{}{0em}{}
\BLOCK{elif config.section_case == 'uppercase'}
\titleformat{\section}{\normalsize\bfseries\MakeUppercase}{}{0em}{}[\vspace{-4pt}\rule{\textwidth}{0.4pt}]
\BLOCK{else}
\titleformat{\section}{\large\bfseries\scshape}{}{0em}{}[\titlerule]
\BLOCK{endif}

\BLOCK{if config.compact}
\titlespacing*{\section}{0pt}{4pt}{3pt}
\BLOCK{else}
\titlespacing*{\section}{0pt}{6pt}{4pt}
\BLOCK{endif}

\begin{document}

%# --- Header ---
\BLOCK{if config.header_centered}
\begin{center}
  \BLOCK{if config.accent_color}{\LARGE\bfseries\color{accent} \VAR{header_data.name | default('Your Name', true) | escape_latex}}\BLOCK{else}{\LARGE\bfseries \VAR{header_data.name | default('Your Name', true) | escape_latex}}\BLOCK{endif} \\[4pt]
  \small
  \BLOCK{if header_data.email}\href{mailto:\VAR{header_data.email | escape_latex}}{\VAR{header_data.email | escape_latex}}\BLOCK{endif}
  \BLOCK{if header_data.phone} $|$ \VAR{header_data.phone | escape_latex}\BLOCK{endif}
  \BLOCK{if header_data.linkedin} $|$ \href{https://\VAR{header_data.linkedin | escape_latex}}{\VAR{header_data.linkedin | escape_latex}}\BLOCK{endif}
  \BLOCK{if header_data.github} $|$ \href{https://\VAR{header_data.github | escape_latex}}{\VAR{header_data.github | escape_latex}}\BLOCK{endif}
  \BLOCK{if header_data.website} $|$ \href{https://\VAR{header_data.website | escape_latex}}{\VAR{header_data.website | escape_latex}}\BLOCK{endif}
\end{center}
\BLOCK{else}
{\LARGE\bfseries \VAR{header_data.name | default('Your Name', true) | escape_latex}} \hfill
\small
\BLOCK{if header_data.email}\href{mailto:\VAR{header_data.email | escape_latex}}{\VAR{header_data.email | escape_latex}}\BLOCK{endif}
\BLOCK{if header_data.phone} $|$ \VAR{header_data.phone | escape_latex}\BLOCK{endif}
\BLOCK{if header_data.linkedin} $|$ \href{https://\VAR{header_data.linkedin | escape_latex}}{\VAR{header_data.linkedin | escape_latex}}\BLOCK{endif}
\BLOCK{if header_data.github} $|$ \href{https://\VAR{header_data.github | escape_latex}}{\VAR{header_data.github | escape_latex}}\BLOCK{endif}
\BLOCK{if header_data.website} $|$ \href{https://\VAR{header_data.website | escape_latex}}{\VAR{header_data.website | escape_latex}}\BLOCK{endif}
\BLOCK{endif}

%%j2 for section in sections
%%j2 if section.entries

\BLOCK{if section.type == 'education'}
\section{\VAR{section.title | escape_latex}}
%%j2 for item in section.entries
\textbf{\VAR{item.institution | default('') | escape_latex}} \hfill \VAR{item.location | default('') | escape_latex} \\
\textit{\VAR{item.degree | default('') | escape_latex}} \hfill \textit{\VAR{item.end | default('') | escape_latex}}
%%j2 if item.coursework
\begin{itemize}
  \item \VAR{item.coursework | escape_latex}
\end{itemize}
%%j2 endif
\BLOCK{if config.compact}\BLOCK{else}\vspace{2pt}\BLOCK{endif}
%%j2 endfor
\BLOCK{endif}

\BLOCK{if section.type == 'experience'}
\section{\VAR{section.title | escape_latex}}
%%j2 for item in section.entries
\textbf{\VAR{item.role | default('') | escape_latex}} \hfill \VAR{item.location | default('') | escape_latex} \\
\textit{\VAR{item.company | default('') | escape_latex}} \hfill \textit{\VAR{item.start | default('') | escape_latex} -- \VAR{item.end | default('') | escape_latex}}
%%j2 if item.bullets
\begin{itemize}
%%j2 for bullet in item.bullets
  \item \VAR{bullet.text | escape_latex}
%%j2 endfor
\end{itemize}
%%j2 endif
\BLOCK{if config.compact}\BLOCK{else}\vspace{2pt}\BLOCK{endif}
%%j2 endfor
\BLOCK{endif}

\BLOCK{if section.type == 'project'}
\section{\VAR{section.title | escape_latex}}
%%j2 for item in section.entries
\textbf{\VAR{item.name | default('') | escape_latex}}
\BLOCK{if item.tech_stack} $|$ \textit{\VAR{item.tech_stack | escape_latex}}\BLOCK{endif}
\BLOCK{if item.url} $|$ \href{https://\VAR{item.url | escape_latex}}{\small \VAR{item.url | escape_latex}}\BLOCK{endif}
%%j2 if item.bullets
\begin{itemize}
%%j2 for bullet in item.bullets
  \item \VAR{bullet.text | escape_latex}
%%j2 endfor
\end{itemize}
%%j2 endif
%%j2 endfor
\BLOCK{endif}

\BLOCK{if section.type == 'skills'}
\section{\VAR{section.title | escape_latex}}
\begin{itemize}[label={}]
%%j2 for item in section.entries
  \item \textbf{\VAR{item.name | default('') | escape_latex}:} \VAR{item['items'] | default([]) | join(', ') | escape_latex}
%%j2 endfor
\end{itemize}
\BLOCK{endif}

\BLOCK{if section.type == 'generic'}
\section{\VAR{section.title | escape_latex}}
\begin{itemize}
%%j2 for item in section.entries
%%j2 if item.text | default('')
  \item \VAR{item.text | escape_latex}
%%j2 endif
%%j2 endfor
\end{itemize}
\BLOCK{endif}

%%j2 endif
%%j2 endfor

\end{document}
