\BLOCK{if config.accent_color}
\definecolor{accent}{HTML}{\VAR{config.accent_color | replace('#', '')}}
\BLOCK{else}
\definecolor{accent}{HTML}{000000}
\BLOCK{endif}

\pagestyle{empty}
\setlength{\parindent}{0pt}
\BLOCK{if config.compact}
\setlist[itemize]{nosep, leftmargin=1.5em, topsep=1pt}
\BLOCK{else}
\setlist[itemize]{nosep, leftmargin=1.5em, topsep=2pt}
\BLOCK{endif}

%# --- Section heading style ---
\BLOCK{if config.section_style == 'color_rule'}
\titleformat{\section}{\large\bfseries\color{accent}}{}{0em}{}[\color{accent}\titlerule]
\BLOCK{elif config.section_style == 'plain'}
\titleformat{\section}{\large\bfseries}{}{0em}{}
\BLOCK{elif config.section_case == 'uppercase'}
\titleformat{\section}{\normalsize\bfseries\MakeUppercase}{}{0em}{}[\vspace{-4pt}\rule{\textwidth}{0.4pt}]
\BLOCK{else}
\titleformat{\section}{\large\bfseries\scshape}{}{0em}{}[\titlerule]
\BLOCK{endif}

\BLOCK{if config.compact}
\titlespacing*{\section}{0pt}{4pt}{3pt}
\BLOCK{else}
\titlespacing*{\section}{0pt}{6pt}{4pt}
\BLOCK{endif}

\begin{document}

%# --- Header ---
\BLOCK{if config.header_centered}
\begin{center}
  \BLOCK{if config.accent_color}{\LARGE\bfseries\color{accent} \VAR{header.name | default('Your Name') | escape_latex}}\BLOCK{else}{\LARGE\bfseries \VAR{header.name | default('Your Name') | escape_latex}}\BLOCK{endif} \\[4pt]
  \small
  \BLOCK{if header.email}\href{mailto:\VAR{header.email | escape_latex}}{\VAR{header.email | escape_latex}}\BLOCK{endif}
  \BLOCK{if header.phone} $|$ \VAR{header.phone | escape_latex}\BLOCK{endif}
  \BLOCK{if header.linkedin} $|$ \href{https://\VAR{header.linkedin | escape_latex}}{\VAR{header.linkedin | escape_latex}}\BLOCK{endif}
  \BLOCK{if header.github} $|$ \href{https://\VAR{header.github | escape_latex}}{\VAR{header.github | escape_latex}}\BLOCK{endif}
  \BLOCK{if header.website} $|$ \href{https://\VAR{header.website | escape_latex}}{\VAR{header.website | escape_latex}}\BLOCK{endif}
\end{center}
\BLOCK{else}
