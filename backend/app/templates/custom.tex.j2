\BLOCK{if header.linkedin} $|$ \href{https://\VAR{header.linkedin | escape_latex}}{\VAR{header.linkedin | escape_latex}}\BLOCK{endif}
\BLOCK{if header.github} $|$ \href{https://\VAR{header.github | escape_latex}}{\VAR{header.github | escape_latex}}\BLOCK{endif}
